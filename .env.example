# Example file. Real one should never be committed
ANTHROPIC_API_KEY=your-key-here
DATABASE_URL=postgresql://triage:triage_pass@localhost:5432/transaction_triage
NIGHT_AGENT_CUTOFF_HOURS=72
SEED_RANDOM_SEED=17
MODEL_NAME=claude-sonnet-4-6
MAX_TOKENS=4096
MAX_ITERATIONS=80          # more iterations, each cheaper
MAX_RETRIES=5
SEED_TOTAL_TRANSACTIONS=200
# Tier 1 (~10-15 min for 200 tx). Increase batch size at higher tiers.
DAY_AGENT_BATCH_SIZE=50
DAY_AGENT_MAX_TOKENS=1024